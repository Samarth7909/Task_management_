{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": ["/index.html", "/*.css", "/*.js"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "tasks-api",
      "urls": [
        "https://taskmanagement-production-7e17.up.railway.app/api/tasks",
        "https://taskmanagement-production-7e17.up.railway.app/api/tasks/dashboard"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "30s"
      }
    }
  ]
}
